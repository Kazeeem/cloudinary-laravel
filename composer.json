{
  "name": "kazeeem/cloudinary-laravel",
  "description": "A Laravel Cloudinary Package Forked From CloudinaryLabs/cloudinary-laravel with support for Laravel 13",
  "license": "MIT",
  "authors": [
    {
      "name": "Kazeem Asifat",
      "email": "kazeemasifat1@gmail.com",
      "homepage": "https://github.com/Kazeeeem"
    }
  ],
  "homepage": "https://github.com/kazeeem/cloudinary-laravel",
  "keywords": [
    "Laravel",
    "cloudinary-laravel",
    "File Uploads",
    "Media Management",
    "Cloudinary",
    "File Transformations"
  ],
  "require": {
    "php": "^8.2|^8.3",
    "ext-json": "*",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "cloudinary/cloudinary_php": "^2.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "pestphp/pest": "^2.35|^3.0|^4.4",
    "sempro/phpunit-pretty-print": "^1.2",
    "laravel/pint": "^1.20",
    "phpspec/prophecy-phpunit": "^2.3"
  },
  "autoload": {
    "psr-4": {
      "CloudinaryLabs\\CloudinaryLaravel\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "CloudinaryLabs\\CloudinaryLaravel\\CloudinaryServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
